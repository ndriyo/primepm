# =====================================================================
# Local development — Prisma & Supabase Edge Functions
# =====================================================================

# Prisma uses this to run migrations against Supabase Postgres.
# Use the Supavisor pooler URL (works over IPv4) — get it from
# https://supabase.com/dashboard/project/<ref>/settings/database
# (pick "Session" mode for migrations).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# =====================================================================
# Frontend (Vite) — only VITE_* vars are exposed to the browser
# =====================================================================

# Supabase project URL and anonymous (public) key — safe to expose.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<anon-key>"

# Edge Function base URL. Leave empty in local dev to fall back to localStorage.
# Production: https://<project-ref>.supabase.co/functions/v1
VITE_API_URL=""

# =====================================================================
# Supabase Edge Functions runtime — set via `supabase secrets set`
# =====================================================================
# These are auto-injected at runtime by the Supabase platform; you only
# need to set them when running `deno run` locally for portability tests.
#
# SUPABASE_DB_URL=""           # auto-injected; pooler URL (internal)
# SUPABASE_JWT_SECRET=""       # auto-injected; HS256 secret
# ALLOWED_ORIGINS=""           # comma-separated origins for CORS
