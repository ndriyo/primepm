{
  "name": "prime-schedule",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:diff": "prisma migrate diff --from-config-datasource --to-schema prisma/schema.prisma --script",
    "deploy:fn": "supabase functions deploy api --no-verify-jwt",
    "deploy:web": "npm run build && wrangler pages deploy dist --project-name=prime-schedule"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-virtual": "^3.13.6",
    "@use-gesture/react": "^10.3.1",
    "chrono-node": "^2.7.7",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "immer": "^10.1.1",
    "lucide-react": "^0.479.0",
    "motion": "^12.4.7",
    "nanoid": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^4.6.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.0.2",
    "zod": "^4.4.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  }
}
